{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/golf-chat.js": {
      "maxDuration": 30
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/assets/:path*",
      "destination": "/docs/assets/:path*"
    },
    {
      "source": "/admin",
      "destination": "/docs/admin.html"
    },
    {
      "source": "/payment/result",
      "destination": "/docs/payment-result.html"
    },
    {
      "source": "/manifest.webmanifest",
      "destination": "/docs/manifest.webmanifest"
    },
    {
      "source": "/sw.js",
      "destination": "/docs/sw.js"
    },
    {
      "source": "/icons/:path*",
      "destination": "/docs/icons/:path*"
    },
    {
      "source": "/",
      "destination": "/docs/jp-golf.html"
    }
  ]
}
