{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/golf-chat.js": {
      "maxDuration": 30
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "destination": "/docs/jp-golf.html"
    }
  ]
}
